---
interface Props {
  messages: Record<string, any>;
}
const { messages } = Astro.props;
const eco = messages.eco;
---

<section id="eco" class="py-20 bg-sand text-ink">
  <div class="max-w-7xl mx-auto px-5">
    <p class="font-hand text-gold text-xl md:text-2xl">{eco.label}</p>
    <h2 class="font-display font-semibold text-3xl md:text-5xl text-teak mt-2">{eco.heading}</h2>

    <blockquote class="border-l-4 border-gold pl-5 italic text-teak font-display text-xl my-6 max-w-3xl">
      “{eco.quote}”
    </blockquote>

    <p class="max-w-3xl text-ink/85">{eco.intro}</p>

    <!-- SVG Floor Plan -->
    <div class="mt-10 max-w-4xl mx-auto bg-white/70 rounded-2xl border border-gold/30 p-6 md:p-8 shadow-sm">
      <h3 class="font-display text-xl text-teak mb-6 text-center">Interactive Plan of Bang Pa-In Palace</h3>
      
      <div class="relative flex flex-col md:flex-row gap-6">
        <div class="relative w-full md:w-2/3 aspect-[4/3] max-h-[500px] overflow-hidden">
          <!-- Minimalist SVG Map -->
          <svg viewBox="0 0 800 600" class="w-full h-full text-ink/60 font-sans" xmlns="http://www.w3.org/2000/svg">
            <!-- Background Grid / Water -->
            <rect width="100%" height="100%" fill="#fcf9f2" rx="12"/>
            <path d="M 200 150 Q 250 100 400 150 T 700 200 L 700 600 L 200 600 Z" fill="#e5eff1" opacity="0.6"/>
            
            <!-- Paths -->
            <path d="M 150 500 C 300 450 350 250 500 250" fill="none" stroke="#e6dbcc" stroke-width="8" stroke-dasharray="10 5" stroke-linecap="round"/>
            <path d="M 500 250 C 550 250 650 350 600 450" fill="none" stroke="#e6dbcc" stroke-width="8" stroke-dasharray="10 5" stroke-linecap="round"/>
            <path d="M 350 350 L 500 350" fill="none" stroke="#e6dbcc" stroke-width="8" stroke-dasharray="10 5" stroke-linecap="round"/>

            <!-- Entrance -->
            <rect x="120" y="480" width="40" height="40" rx="4" fill="#d9ceb8"/>
            <text x="140" y="540" font-size="12" text-anchor="middle" font-weight="600" fill="#8c7a5f">ENTRANCE</text>

            <!-- Aisawan Thiphya-Art (Thai) -->
            <g class="interactive-building cursor-pointer transition-transform hover:scale-105" transform-origin="350 250" onclick="showBuildingDetails('Aisawan Thiphya-Art', 'Thai Style', 'The iconic floating pavilion in the center of the lake.')">
              <circle cx="350" cy="250" r="35" fill="#c9a962" opacity="0.2"/>
              <polygon points="350,220 330,260 370,260" fill="#c9a962"/>
              <circle cx="350" cy="250" r="40" fill="transparent" />
              <text x="350" y="295" font-size="14" text-anchor="middle" font-weight="600" fill="#5c4d3c">Aisawan Thiphya-Art</text>
            </g>

            <!-- Wehart Chamrun (Chinese) -->
            <g class="interactive-building cursor-pointer transition-transform hover:scale-105" transform-origin="500 125" onclick="showBuildingDetails('Wehart Chamrun', 'Chinese Style', 'A two-story mansion presented by the Chinese chamber of commerce. Built without a single iron nail.')">
              <rect x="450" y="95" width="100" height="60" rx="4" fill="#a84040" opacity="0.8"/>
              <text x="500" y="175" font-size="14" text-anchor="middle" font-weight="600" fill="#5c4d3c">Wehart Chamrun</text>
            </g>

            <!-- Uthayan Phumisathian (European) -->
            <g class="interactive-building cursor-pointer transition-transform hover:scale-105" transform-origin="500 350" onclick="showBuildingDetails('Uthayan Phumisathian', 'European Style', 'A Neo-Renaissance styled mansion favored by King Rama V.')">
              <rect x="450" y="320" width="100" height="60" rx="4" fill="#5b7065" opacity="0.8"/>
              <text x="500" y="400" font-size="14" text-anchor="middle" font-weight="600" fill="#5c4d3c">Uthayan Phumisathian</text>
            </g>

            <!-- Withun Thatsana (Lookout Tower) -->
            <g class="interactive-building cursor-pointer transition-transform hover:scale-105" transform-origin="620 250" onclick="showBuildingDetails('Withun Thatsana', 'Lookout Tower', 'An Italianate tower providing 360-degree views of the river and palace.')">
              <circle cx="620" cy="250" r="20" fill="#5b7065" opacity="0.8"/>
              <circle cx="620" cy="250" r="8" fill="#fcf9f2"/>
              <text x="620" y="290" font-size="12" text-anchor="middle" font-weight="600" fill="#5c4d3c">Lookout Tower</text>
            </g>

            <!-- Warophat Phiman -->
            <g class="interactive-building cursor-pointer transition-transform hover:scale-105" transform-origin="280 400" onclick="showBuildingDetails('Warophat Phiman', 'Neo-Classical', 'A throne hall used for state ceremonies and royal receptions.')">
              <rect x="240" y="375" width="80" height="50" rx="4" fill="#5b7065" opacity="0.6"/>
              <text x="280" y="445" font-size="12" text-anchor="middle" font-weight="600" fill="#5c4d3c">Warophat Phiman</text>
            </g>
          </svg>
        </div>

        <!-- Details Panel -->
        <div id="building-details-panel" class="w-full md:w-1/3 flex flex-col justify-center rounded-xl bg-teakDeep text-ivory p-6 hidden">
          <span id="bd-subtitle" class="text-goldBright text-xs font-semibold uppercase tracking-wider mb-1">Select a building</span>
          <h4 id="bd-title" class="font-display text-2xl mb-3">Interactive Map</h4>
          <p id="bd-desc" class="text-sm text-ivory/80 mb-6">Click on any colored building on the map to view details.</p>
          
          <div class="flex flex-col gap-3">
            <button class="flex items-center justify-center gap-2 bg-gold text-teak font-semibold py-2.5 rounded-full hover:bg-goldBright transition-colors w-full">
              <span aria-hidden="true">🌐</span> 360° View
            </button>
            <button class="flex items-center justify-center gap-2 border border-gold/50 text-ivory py-2.5 rounded-full hover:border-goldBright hover:text-goldBright transition-colors w-full">
              <span aria-hidden="true">🎧</span> Play Audio Guide (0:30)
            </button>
          </div>
        </div>
        
        <!-- Default Empty State -->
        <div id="building-empty-state" class="w-full md:w-1/3 flex flex-col items-center justify-center rounded-xl border border-dashed border-gold/40 p-6 text-center">
          <span class="text-4xl mb-3">🗺️</span>
          <p class="text-sm text-ink/60">Click on a building on the map to explore 360° views and audio guides.</p>
        </div>
      </div>
    </div>

    <script is:inline>
      function showBuildingDetails(title, subtitle, desc) {
        document.getElementById('building-empty-state').classList.add('hidden');
        document.getElementById('building-details-panel').classList.remove('hidden');
        document.getElementById('bd-title').textContent = title;
        document.getElementById('bd-subtitle').textContent = subtitle;
        document.getElementById('bd-desc').textContent = desc;
      }
    </script>

    <!-- Microclimate -->
    <h3 class="font-display text-2xl text-teak mt-12 mb-4">{eco.microTitle}</h3>
    <div class="grid md:grid-cols-3 gap-4">
      {eco.micro.map((m) => (
        <div class="rounded-xl border border-gold/25 bg-white/50 p-5">
          <div class="font-semibold text-teak mb-1">{m.title}</div>
          <p class="text-sm text-ink/75">{m.desc}</p>
        </div>
      ))}
    </div>

    <!-- Vertical plants -->
    <h3 class="font-display text-2xl text-teak mt-12 mb-4">{eco.plantsTitle}</h3>
    <div class="space-y-6">
      {eco.plants.map((p) => (
        <div class="rounded-2xl border border-gold/25 bg-white/40 p-6">
          <div class="font-display text-lg text-gold mb-2">{p.title}</div>
          <p class="text-sm text-ink/75 mb-3">{p.desc}</p>
          {p.items && (
            <ul class="space-y-2 text-sm text-ink/75">
              {p.items.map((it) => (
                <li class="flex gap-2">
                  <span class="text-gold mt-0.5" aria-hidden="true">•</span>
                  <span><span class="font-medium text-teak">{it.name}</span> — {it.desc}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </div>

    <!-- Wildlife -->
    <h3 class="font-display text-2xl text-teak mt-12 mb-4">{eco.wildlifeTitle}</h3>
    <ul class="space-y-2 max-w-3xl text-sm text-ink/80">
      {eco.wildlife.map((w) => (
        <li class="flex gap-2">
          <span class="text-gold mt-0.5" aria-hidden="true">•</span>
          <span>{w}</span>
        </li>
      ))}
    </ul>

    <!-- Leave No Trace -->
    <div class="mt-12 rounded-2xl border border-teak/30 bg-teak/5 p-6">
      <h4 class="font-display text-xl text-teak mb-2">{eco.lntTitle}</h4>
      <p class="text-sm text-ink/75 mb-3">{eco.lntIntro}</p>
      <ul class="space-y-2 text-sm text-ink/80">
        {eco.lnt.map((t, i) => (
          <li>
            <label class="flex items-start gap-3 cursor-pointer group rounded-lg px-2 py-1.5 -mx-2 hover:bg-teak/5 transition-colors">
              <input type="checkbox" id={`lnt-${i}`} class="peer mt-0.5 h-5 w-5 shrink-0 accent-teak cursor-pointer" />
              <span class="leading-relaxed peer-checked:line-through peer-checked:text-ink/45 transition-colors">{t}</span>
            </label>
          </li>
        ))}
      </ul>
      {eco.lntCheckHint && (
        <p class="mt-4 text-xs font-medium text-teak/80">{eco.lntCheckHint}</p>
      )}
    </div>

    <!-- Fauna & Flora checklist -->
    {eco.checklist && (
      <div class="mt-12">
        <h3 class="font-display text-2xl text-teak mb-1">{eco.checklist.title}</h3>
        <p class="text-sm text-ink/75 mb-5">{eco.checklist.intro}</p>
        <div class="grid sm:grid-cols-2 gap-4">
          {eco.checklist.items.map((c) => (
            <div class={`rounded-2xl border p-5 ${c.rareClass === 'warn' ? 'border-red-300 bg-red-50' : 'border-gold/25 bg-white/50'}`}>
              <div class="flex items-center gap-3">
                <span class="text-2xl" aria-hidden="true">{c.emoji}</span>
                <span class="font-display text-teak font-semibold text-lg">{c.name}</span>
              </div>
              <p class="mt-2 text-sm text-ink/75"><span class="font-medium text-gold">🗓 {c.best}</span></p>
              <p class="mt-1 text-sm text-ink/70"><span class="font-medium {c.rareClass === 'warn' ? 'text-red-700' : 'text-teak'}">{c.rare}</span></p>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
