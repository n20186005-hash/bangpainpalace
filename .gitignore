# ===== Astro 构建产物（不需要上传） =====
dist/
.astro/

# ===== 依赖（不需要上传） =====
node_modules/

# ===== 日志 / 构建错误产物 =====
*.log
build.err
build.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===== 环境变量（含密钥，绝不入库） =====
.env
.env.production
.env.local
.env.*.local

# ===== 操作系统 / 编辑器 =====
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ===== 临时验证 / 维护脚本（往期站点遗留，已清理） =====
verify.js
verify.cjs
update_*.js
update_*.ps1
rename_*.ps1
rename_*.js
probe_out.txt
scripts/

# ===== 包管理器锁文件（可选：如团队统一用 lock，可注释下行） =====
# package-lock.json

# ===== 保留项说明 =====
# public/gallery/*.jpg  —— 站点真实照片，需入库
# src/                  —— 全部源码，需入库
# index.html / astro.config.mjs / package.json / tsconfig.json —— 入口与配置，需入库
